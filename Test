-- ==================== Drag Handle ====================
-- Invisible frame on title bar area that doesn't overlap buttons
local dragHandle = Instance.new("Frame")
dragHandle.Name = "DragHandle"
dragHandle.Size = UDim2.new(1, -64, 1, 0)  -- leave space for the two buttons
dragHandle.Position = UDim2.new(0, 0, 0, 0)
dragHandle.BackgroundTransparency = 1
dragHandle.Active = true                   -- allows it to capture input
dragHandle.Parent = titleBar

-- Dragging logic
local dragging = false
local dragStart = nil
local startPos = nil

dragHandle.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = window.Position
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		window.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + delta.X,
			startPos.Y.Scale, startPos.Y.Offset + delta.Y
		)
	end
end)

UserInputService.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = false
	end
end)

-- ==================== Minimize / Close Logic ====================
local minimized = false
local originalSize = window.Size  -- save original size

minimizeButton.MouseButton1Click:Connect(function()
	minimized = not minimized
	if minimized then
		-- Save original size if not already saved
		originalSize = window.Size
		content.Visible = false
		-- Shrink window to title bar height
		window.Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, 0, 32)
	else
		content.Visible = true
		window.Size = originalSize
	end
end)

closeButton.MouseButton1Click:Connect(function()
	-- Toggle window visibility (close / reopen)
	window.Visible = not window.Visible
	-- If reopened and was minimized, restore original state
	if window.Visible and minimized then
		minimized = false
		content.Visible = true
		window.Size = originalSize
	end
end)

